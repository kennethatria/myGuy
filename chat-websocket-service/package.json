{
  "name": "chat-websocket-service",
  "version": "1.0.0",
  "description": "WebSocket service for real-time chat functionality in MyGuy platform",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest",
    "lint": "eslint src/",
    "migrate": "node src/scripts/migrate-simple.js",
    "migrate:old": "node src/scripts/migrate.js",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down"
  },
  "dependencies": {
    "@opentelemetry/exporter-zipkin": "^2.6.1",
    "@opentelemetry/instrumentation-express": "^0.62.0",
    "@opentelemetry/instrumentation-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-cron": "^3.0.3",
    "node-pg-migrate": "^8.0.3",
    "pg": "^8.20.0",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "socket.io-client": "^4.7.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverage": true,
    "collectCoverageFrom": [
      "src/utils/contentFilter.js",
      "src/middleware/auth.js",
      "src/services/messageService.js",
      "src/services/validationService.js",
      "src/services/bookingMessageService.js",
      "src/api/bookingNotifications.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 70,
        "functions": 70,
        "statements": 70,
        "branches": 60
      }
    },
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
