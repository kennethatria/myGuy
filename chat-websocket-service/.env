PORT=8082
NODE_ENV=development
LOG_LEVEL=info

# Database connection string
DB_CONNECTION=postgresql://postgres:password@localhost:5432/myguy

# JWT Secret (must match main backend service)
JWT_SECRET=your-secret-key

# Client URL for CORS
CLIENT_URL=http://localhost:5173

# Store API URL for booking actions
STORE_API_URL=http://localhost:8081/api/v1

# Internal API key for service-to-service communication (must match store-service)
INTERNAL_API_KEY=your-internal-api-key-change-in-production

# Redis Configuration (optional - enables multi-instance horizontal scaling)
# If not configured, falls back to in-memory adapter (single instance only)
#
# Option 1: Full URL (recommended for cloud services like Redis Cloud, Upstash, etc.)
# REDIS_URL=redis://username:password@hostname:6379/0
#
# Option 2: Individual settings (for local development)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/my_guy_chat 
CLIENT_URL=http://localhost:5173                                                                                             
ZIPKIN_URL=http://localhost:9411/api/v2/spans