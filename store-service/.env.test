# Test Environment Configuration
# This file contains environment variables used during testing

# Database Configuration
DB_CONNECTION="host=localhost user=test_user password=test_password dbname=store_test port=5432 sslmode=disable"
TEST_DB_CONNECTION="file::memory:?cache=shared"

# JWT Configuration  
JWT_SECRET="test-jwt-secret-key-for-testing-only"

# Server Configuration
PORT=8081
GIN_MODE=test

# File Upload Configuration
UPLOAD_DIR="./test_uploads"
MAX_FILE_SIZE=5242880

# Test Configuration
TEST_TIMEOUT=30s
TEST_VERBOSE=true

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json